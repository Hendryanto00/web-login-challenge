JWT_SECRET=ganti-dengan-string-rahasia-panjang
NODE_ENV=development

# Otomatis setelah npm install: skrip membuat DB + tabel users (MySQL harus jalan).
# Lewati: SKIP_DB_AUTO_SETUP=true
# Tanpa user contoh: SKIP_DB_SEED=true

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=login_app

# Set true jika tabel users punya kolom username (login email ATAU username)
# Default / kosong = hanya kolom email + password (tanpa username)
DB_HAS_USERNAME=false

# CORS (origin frontend)
FRONTEND_ORIGIN=http://localhost:3000

